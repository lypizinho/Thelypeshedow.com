<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Pega-Pega</title>

<style>
  body {
    text-align: center;
    background: #111;
    color: white;
    font-family: Arial;
  }

  #area {
    width: 400px;
    height: 400px;
    background: #222;
    margin: 20px auto;
    position: relative;
    border-radius: 10px;
    box-shadow: 0 0 20px black;
  }

  .player, .enemy {
    width: 30px;
    height: 30px;
    position: absolute;
    border-radius: 6px;
  }

  .player {
    background: linear-gradient(45deg, #00c6ff, #0072ff);
  }

  .enemy {
    background: linear-gradient(45deg, red, darkred);
  }
</style>
</head>

<body>

<h1>🏃‍♂️ Pega-Pega</h1>
<p>Tempo sobrevivido: <span id="tempo">0</span>s</p>
<button onclick="reiniciar()">🔄 Recomeçar</button>

<div id="area">
  <div id="player" class="player"></div>
</div>

<script>

// ================== VARIÁVEIS ==================
let player = document.getElementById("player");

let x = 180, y = 180;
let velocidade = 5;

let enemies = [];
let enemyElements = [];
let velocidadeInimigo = 2;

let tempo = 0;
let ultimoTempo = 0;
let jogoRodando = true;

// ================== INÍCIO ==================
player.style.left = x + "px";
player.style.top = y + "px";

criarInimigo();

// ================== CONTROLE ==================
let teclas = {};

document.addEventListener("keydown", (e) => teclas[e.key] = true);
document.addEventListener("keyup", (e) => teclas[e.key] = false);

// ================== FUNÇÕES ==================

function moverPlayer() {
  if (!jogoRodando) return;

  if (teclas["ArrowUp"]) y -= velocidade;
  if (teclas["ArrowDown"]) y += velocidade;
  if (teclas["ArrowLeft"]) x -= velocidade;
  if (teclas["ArrowRight"]) x += velocidade;

  x = Math.max(0, Math.min(370, x));
  y = Math.max(0, Math.min(370, y));

  player.style.left = x + "px";
  player.style.top = y + "px";
}

function criarInimigo() {
  let ex = Math.random() * 370;
  let ey = Math.random() * 370;

  enemies.push({x: ex, y: ey});

  let novo = document.createElement("div");
  novo.classList.add("enemy");
  document.getElementById("area").appendChild(novo);

  enemyElements.push(novo);
}

function moverInimigos() {
  if (!jogoRodando) return;

  enemies.forEach((e, i) => {
    if (e.x < x) e.x += velocidadeInimigo;
    if (e.x > x) e.x -= velocidadeInimigo;
    if (e.y < y) e.y += velocidadeInimigo;
    if (e.y > y) e.y -= velocidadeInimigo;

    enemyElements[i].style.left = e.x + "px";
    enemyElements[i].style.top = e.y + "px";

    if (Math.abs(x - e.x) < 25 && Math.abs(y - e.y) < 25) {
      jogoRodando = false;
      alert("💀 Você foi pego! Tempo: " + tempo + "s");
    }
  });

  velocidadeInimigo = 2 + tempo * 0.1;
}

function reiniciar() {
  x = 180; y = 180;
  tempo = 0;
  ultimoTempo = 0;
  jogoRodando = true;

  enemies = [];
  enemyElements.forEach(e => e.remove());
  enemyElements = [];

  criarInimigo();

  player.style.left = x + "px";
  player.style.top = y + "px";

  document.getElementById("tempo").innerText = 0;
}

// ================== LOOP ==================

function loop(agora) {
  if (!jogoRodando) return;

  moverPlayer();
  moverInimigos();

  // tempo
  if (agora - ultimoTempo >= 1000) {
    tempo++;
    document.getElementById("tempo").innerText = tempo;
    ultimoTempo = agora;
  }

  // novos inimigos
  if (tempo > 0 && tempo % 5 === 0 && enemies.length < tempo / 5 + 1) {
    criarInimigo();
  }

  requestAnimationFrame(loop);
}

requestAnimationFrame(loop);

</script>

</body>
</html>
